# ──────────────────────────────────────────
#  Opción A — Alibaba DashScope (Qwen3)
#  Recomendado: es el mismo proveedor del curso
# ──────────────────────────────────────────
ALIBABA_API_KEY=tu-api-key-de-alibaba
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ──────────────────────────────────────────
#  Opción B — OpenAI
#  Descomentá estas líneas y comentá las de arriba
# ──────────────────────────────────────────
# OPENAI_API_KEY=tu-api-key-de-openai
# LLM_MODEL=gpt-3.5-turbo

# ──────────────────────────────────────────
#  LLM
# ──────────────────────────────────────────
LLM_TEMPERATURE=0.7

# ──────────────────────────────────────────
#  RAG — FAISS + embeddings locales
# ──────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
FAISS_INDEX_PATH=data/faiss_index

# ──────────────────────────────────────────
#  Memoria conversacional
# ──────────────────────────────────────────
MEMORY_K=8

# ──────────────────────────────────────────
#  CORS — orígenes permitidos (separar con coma)
# ──────────────────────────────────────────
CORS_ORIGINS=https://landingbot.qhipa.org.pe,https://factufacil.pe

# ──────────────────────────────────────────
#  Servidor
# ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
